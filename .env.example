# ============================================================
# OxyScale Dialler — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Twilio (browser-based calling)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=

# Deepgram (real-time transcription)
DEEPGRAM_API_KEY=

# Anthropic (AI summaries & email drafts)
ANTHROPIC_API_KEY=

# Email (SendGrid or Resend)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=OxyScale

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# App
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Lead cycler settings
UNANSWERED_CALL_THRESHOLD=3
